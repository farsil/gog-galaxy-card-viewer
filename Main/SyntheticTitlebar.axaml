<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GogGalaxyCardViewer.Main.SyntheticTitlebar"
             IsVisible="False">
    <UserControl.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="TextBlock.Foreground"
                    Value="{DynamicResource SystemBaseMediumHighColor}" />
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="TextBlock.Foreground"
                    Value="{DynamicResource SystemBaseMediumLowColor}" />
        </Style>
    </UserControl.Styles>

    <StackPanel Margin="8 4"
                Height="32"
                Spacing="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
        <Button x:Name="MinimizeButton"
                Content="🗕"
                Padding="0 0 0 4"
                Click="HandleMinimizeButtonClick" />
        <Button x:Name="MaximizeToggleButton"
                Content="🗖"
                Padding="0 0 0 2"
                Click="HandleMaximizeToggleButtonClick" />
        <Button x:Name="CloseButton"
                Content="✕"
                Padding="0"
                Click="HandleCloseButtonClick" />
    </StackPanel>
</UserControl>